
<section class="settings">
    <h1>Configurações</h1>
    <p class="settings-subtitle">Gerencie os dados e o acesso da conta do operador</p>

    <div class="profile-container">
        <div class="profile-card">
            <div class="profile-header">
                <i class="bi bi-person-badge"></i>
                <h2>Perfil do Utilizador</h2>
            </div>

            <div class="profile-info-list">
                <div class="info-item">
                    <span class="info-label">ID do Sistema:</span>
                    <span class="info-value">#001</span>
                </div>

                <div class="info-item">
                    <span class="info-label">Nome:</span>
                    <span class="info-value">Operador Principal</span>
                </div>

                <div class="info-item">
                    <span class="info-label">E-mail:</span>
                    <span class="info-value">operador@sistema.com</span>
                </div>

                <div class="info-item">
                    <span class="info-label">Cargo / Função:</span>
                    <span class="info-value text-role">Administrador</span>
                </div>
            </div>

            <button type="button" id="logoutBtn" class="logout-button">
                <i class="bi bi-box-arrow-right"></i>
                <span>Terminar Sessão</span>
            </button>
        </div>
    </div>
</section>